<div class="border-4 border-slate-900 p-8 bg-white shadow-[8px_8px_0px_0px_rgba(168,85,247,1)] my-6">
  <h3 class="text-2xl font-black mb-6 uppercase italic">Le Radar de Vol Bimodal</h3>
  <p class="text-sm mb-6 font-bold text-slate-600">Planifiez vos cycles comme le Martinet Noir pour éviter le crash cognitif.</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
    <!-- Entrée des cycles -->
    <div class="space-y-4">
      <div class="p-4 bg-purple-100 border-2 border-slate-900">
        <label class="block font-black text-xs uppercase">Temps de Focus (Hémisphère A)</label>
        <input type="range" min="30" max="180" value="90" class="w-full accent-purple-600" id="focus-range">
        <span id="focus-val" class="font-bold">90 min</span>
      </div>
      <div class="p-4 bg-emerald-100 border-2 border-slate-900">
        <label class="block font-black text-xs uppercase">Temps de Digestion (Hémisphère B)</label>
        <input type="range" min="15" max="60" value="20" class="w-full accent-emerald-600" id="rest-range">
        <span id="rest-val" class="font-bold">20 min</span>
      </div>
    </div>

    <!-- Feedback Dynamique -->
    <div id="flight-status" class="flex flex-col justify-center items-center border-2 border-dashed border-slate-300 p-4">
      <div id="status-icon" class="text-4xl mb-2">🐦</div>
      <p id="status-text" class="font-black text-center text-sm uppercase"></p>
      <p id="status-desc" class="text-xs text-center mt-2"></p>
    </div>
  </div>

  <!-- Lien avec la recherche -->
  <div class="mt-6 pt-4 border-t-2 border-slate-200 text-xs text-slate-500 italic">
    🔗 Inspiré du sommeil unilatéral du martinet noir. Ratio optimal : Focus/Digestion entre 2 et 5.
  </div>
</div>

<script>
  const fRange = document.getElementById('focus-range');
  const rRange = document.getElementById('rest-range');
  
  function updateFlight() {
    const f = parseInt(fRange.value);
    const r = parseInt(rRange.value);
    document.getElementById('focus-val').innerText = `${f} min`;
    document.getElementById('rest-val').innerText = `${r} min`;

    const ratio = f / r;
    const statusText = document.getElementById('status-text');
    const statusDesc = document.getElementById('status-desc');
    const statusIcon = document.getElementById('status-icon');

    if (ratio > 5) {
      statusText.innerText = "⚠️ RISQUE DE CRASH";
      statusDesc.innerText = "Trop de focus, pas assez de digestion. Votre cerveau va saturer (asphyxie cognitive).";
      statusText.style.color = "#dc2626";
      statusIcon.innerText = "💥";
    } else if (ratio < 2) {
      statusText.innerText = "🐌 VOL STATIONNAIRE";
      statusDesc.innerText = "Trop de repos. Vous ne générez pas assez de portance pour progresser.";
      statusText.style.color = "#ea580c";
      statusIcon.innerText = "🐥";
    } else {
      statusText.innerText = "✨ VITESSE DE CROISIÈRE OPTIMALE";
      statusDesc.innerText = "Équilibre parfait. Comme le martinet, vous pouvez rester en vol indéfiniment.";
      statusText.style.color = "#16a34a";
      statusIcon.innerText = "🦅";
    }
  }

  fRange.addEventListener('input', updateFlight);
  rRange.addEventListener('input', updateFlight);
  updateFlight();
</script>
