---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

// 1️⃣ Récupérer tous les articles
const posts = await getCollection("blog");

// 2️⃣ Générer les routes /tags/*
export async function getStaticPaths() {
  const posts = await getCollection("blog");

  // récupérer tous les tags uniques
  const tags = new Set();

  posts.forEach(post => {
    (post.data.tags ?? []).forEach(tag => tags.add(tag));
  });

  return Array.from(tags).map(tag => ({
    params: { tag }
  }));
}

// 3️⃣ Tag courant
const { tag } = Astro.params;

// 4️⃣ Articles ayant ce tag
const postsWithTag = posts
  .filter(post => (post.data.tags ?? []).includes(tag))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={`Tag : ${tag}`} description={`Articles tagués ${tag}`}>
  <h1 class="text-3xl font-bold text-blue-800 mb-2">Tag : #{tag}</h1>
  <p class="text-gray-500 mb-8">{postsWithTag.length} article{postsWithTag.length > 1 ? 's' : ''}</p>

  <ul class="space-y-6">
    {postsWithTag.map(post => (
      <li class="border-b pb-4">
        <a href={`/blog/${post.slug}`} class="text-xl font-semibold text-blue-700 hover:underline">
          {post.data.title}
        </a>
        <p class="text-sm text-gray-500 mt-1">{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>