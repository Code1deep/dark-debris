---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Accueil" description="Ingénieur-pédagogue – Recherche doctorale en technologie éducative">
  <!-- Section héros -->
  <section class="text-center py-12">
    <h1 class="text-4xl font-bold text-blue-800 mb-4">A. ELBAH</h1>
    <p class="text-xl text-gray-600 mb-2">Ingénieur-pédagogue</p>
    <p class="text-gray-500">Conception de dispositifs pédagogiques instrumentés par les données</p>
    <p class="text-gray-400 text-sm mt-2">Design-Based Research · Systèmes complexes · Living Lab</p>
    <div class="flex justify-center gap-4 mt-6">
      <a href="/links" class="bg-blue-800 text-white px-6 py-2 rounded-full hover:bg-blue-700">Portefeuille académique</a>
    </div>
  </section>

  <!-- Section rapide : 3 piliers -->
  <section class="grid md:grid-cols-3 gap-6 py-12 border-t">
    <div class="text-center">
      <h3 class="font-bold text-lg">🎓 Recherche</h3>
      <p class="text-sm text-gray-600">Thèse par articles – DBR – Obstacles cognitifs</p>
    </div>
    <div class="text-center">
      <h3 class="font-bold text-lg">🔧 Ingénierie</h3>
      <p class="text-sm text-gray-600">Living Lab – IoT – Base de Données Intelligente</p>
    </div>
    <div class="text-center">
      <h3 class="font-bold text-lg">📚 Pédagogie</h3>
      <p class="text-sm text-gray-600">10 ans d'accompagnement longitudinal</p>
    </div>
  </section>
</BaseLayout>

