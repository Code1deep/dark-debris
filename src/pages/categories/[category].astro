---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const categories = [
    'epistemologie',
    'obstacles-cognitifs',
    'methodologie-dbr',
    'bdi-et-donnees',
    'parcours',
    'didactique-systemes',
  ];

  return categories.map((slug) => ({
    params: { category: slug },
  }));
}

const { category } = Astro.params;

// labels humains (UNIQUEMENT pour affichage)
const labels = {
  epistemologie: '🔬 Épistémologie',
  'obstacles-cognitifs': '🧠 Obstacles cognitifs',
  'methodologie-dbr': '🔄 Méthodologie DBR',
  'bdi-et-donnees': '📊 BDI et données',
  parcours: '🧭 Parcours et réflexivité',
  'didactique-systemes': '🌱 Didactique des systèmes complexes',
};

const categoryName = labels[category] ?? category;

const allPosts = await getCollection('blog');

const posts = allPosts
  .filter((post) => post.data.categories?.includes(category))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title={categoryName} description={`Articles sur : ${categoryName}`}>
  <h1 class="text-3xl font-bold text-blue-800 mb-2">{categoryName}</h1>
  <p class="text-gray-500 mb-8">
    {posts.length} article{posts.length > 1 ? 's' : ''}
  </p>

  <ul class="space-y-6">
    {posts.map((post) => (
      <li class="border-b pb-4">
        <a href={`/blog/${post.slug}`} class="text-xl font-semibold text-blue-700 hover:underline">
          {post.data.title}
        </a>
        <p class="text-sm text-gray-500 mt-1">{post.data.description}</p>
      </li>
    ))}
  </ul>
</BaseLayout>