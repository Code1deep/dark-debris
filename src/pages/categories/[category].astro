---
import { getCollection } from "astro:content";

// 1️⃣ On récupère tous les articles
const posts = await getCollection("blog");

// 2️⃣ On fabrique la map des catégories
const categoryMap = {};

for (const post of posts) {
  const category = post.data.category ?? "uncategorized";

  if (!categoryMap[category]) {
    categoryMap[category] = [];
  }

  categoryMap[category].push(post);
}

// 3️⃣ Génération des routes statiques
export async function getStaticPaths() {
  const posts = await getCollection("blog");

  const categories = new Set(
    posts.map(post => post.data.category ?? "uncategorized")
  );

  return Array.from(categories).map(category => ({
    params: { category },
  }));
}

// 4️⃣ Récupération catégorie courante
const { category } = Astro.params;
const postsInCategory = categoryMap[category] ?? [];
---

<h1>Catégorie : {category}</h1>

<ul>
  {postsInCategory.map(post => (
    <li>
      <a href={`/blog/${post.slug}/`}>
        {post.data.title}
      </a>
    </li>
  ))}
</ul>
