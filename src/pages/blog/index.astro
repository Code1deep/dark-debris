---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categories = [
  { slug: 'epistemologie', label: '🔬 Épistémologie', color: 'bg-purple-100 text-purple-800' },
  { slug: 'obstacles-cognitifs', label: '🧠 Obstacles cognitifs', color: 'bg-red-100 text-red-800' },
  { slug: 'methodologie-dbr', label: '🔄 Méthodologie DBR', color: 'bg-green-100 text-green-800' },
  { slug: 'bdi-et-donnees', label: '📊 BDI et données', color: 'bg-blue-100 text-blue-800' },
  { slug: 'parcours', label: '🧭 Parcours', color: 'bg-amber-100 text-amber-800' },
  { slug: 'didactique-systemes', label: '🌱 Didactique', color: 'bg-teal-100 text-teal-800' },
];
---

<BaseLayout title="Blog DBR" description="Articles de recherche – Design-Based Research">
  <h1 class="text-3xl font-bold text-blue-800 mb-4">Blog DBR</h1>
  <p class="text-gray-500 mb-6">Articles de recherche sur la didactique des systèmes complexes</p>

  <!-- Filtres par catégorie -->
  <nav class="flex flex-wrap gap-2 mb-10">
    {(post.data.categories ?? []).map((cat: string) => (
        <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{cat}</span>
    ))}
  </nav>

  <!-- Liste des articles -->
  <ul class="space-y-8">
    {posts.map((post) => (
      <li class="border-b pb-6">
        <div class="flex items-center gap-2 mb-1">
          {post.data.niveau === 'initiation' && (
            <span class="text-xs bg-green-100 text-green-700 px-2 py-0.5 rounded">Initiation</span>
          )}
          {post.data.series && (
            <span class="text-xs bg-gray-200 text-gray-600 px-2 py-0.5 rounded">
              {post.data.series} ({post.data.seriesOrder}/3)
            </span>
          )}
          {post.data.readingTime && (
            <span class="text-xs text-gray-400">{post.data.readingTime} min</span>
          )}
        </div>
        <a href={`/blog/${post.slug}`} class="text-xl font-semibold text-blue-700 hover:underline">
          {post.data.title}
        </a>
        <p class="text-sm text-gray-500 mt-1">{post.data.description}</p>
        <div class="flex gap-2 mt-2 flex-wrap">
          {post.data.categories.map((cat: string) => (
            <span class="text-xs bg-gray-100 text-gray-600 px-2 py-0.5 rounded">{cat}</span>
          ))}
        </div>
      </li>
    ))}
  </ul>
</BaseLayout>
