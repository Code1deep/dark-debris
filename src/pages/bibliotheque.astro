---
import BaseLayout from '../layouts/BaseLayout.astro';
import VoyageurTest from '../components/VoyageurTest.astro';
---


<BaseLayout title="Bibliothèque scientifique" description="Mes ouvrages sur la technologie éducative et la productique">
  <section class="max-w-6xl mx-auto py-16 px-4">
    <h1 class="text-4xl font-black italic mb-12 border-b-8 border-slate-900 pb-4">MA BIBLIOTHÈQUE SCIENTIFIQUE</h1>
    
    <div class="grid md:grid-cols-2 gap-12">
     
      <!-- LIVRE 1 : GESTATION NUMÉRIQUE -->
      <div class="group cursor-pointer">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(37,99,235,1)] group-hover:shadow-none transition-all">
          <div class="text-blue-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">L'Utérus Productique</h2>
            <div class="h-2 w-20 bg-blue-500 mb-4"></div>
            <p class="text-blue-100 text-lg font-bold italic">Tome 1 : Gestation d'une Technologie Éducative Numérique</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Instrumentation & Alchimie Algorithmique</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Comment" : L'algorithme comme milieu nutritif de l'apprentissage.</p>
      </div>

      <!-- LIVRE 2 : GESTATION PRODUCTIVE -->
      <div class="group cursor-pointer">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(234,179,8,1)] group-hover:shadow-none transition-all">
          <div class="text-yellow-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">L'Utérus Productique</h2>
            <div class="h-2 w-20 bg-yellow-500 mb-4"></div>
            <p class="text-yellow-100 text-lg font-bold italic">Tome 2 : Gestation d'une Technologie Éducative Productive</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Impact Social & Économie du Savoir</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Pour quoi" : De la solitude artisanale à la démocratisation du savoir.</p>
      </div>
      



      <!-- LIVRE 4 : LE PROTOCOLE BARGE ROUSSE -->
      <div class="group cursor-pointer">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(14,165,233,1)] group-hover:shadow-none transition-all">
          <div class="text-sky-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">Le Protocole Barge Rousse</h2>
            <div class="h-2 w-20 bg-sky-500 mb-4"></div>
            <p class="text-sky-100 text-lg font-bold italic">L'autonomie comme réflexe magnétique dans le flux d'information.</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Bio-résilience & Auto-régulation</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Comment survivre" : Transformer l'apprenant en un navigateur capable de traverser 11 000 km de complexité.</p>
      </div>
      <!-- LIVRE 5 : LA MAINTENANCE DU VOYAGEUR -->
      <div class="group cursor-pointer">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(34,197,94,1)] group-hover:shadow-none transition-all">
          <div class="text-green-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">La Maintenance du Voyageur</h2>
          <div class="h-2 w-20 bg-green-500 mb-4"></div>
          <p class="text-green-100 text-lg font-bold italic">Tome 5 : L'intervalle de tolérance du vivant</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Usure & Résilience Cognitive</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Comment durer" : Calculer l'usure pour garantir la traversée.</p>
      </div>


      <!-- Section Test du Voyageur -->
      <section class="mt-16">
        <VoyageurTest />
      </section>
    </div>
  </section>
</BaseLayout>