---
import BaseLayout from '../layouts/BaseLayout.astro';
import VoyageurTest from '../components/VoyageurTest.astro';
---


<BaseLayout title="Bibliothèque scientifique" description="Mes ouvrages sur la technologie éducative et la productique">
  <section class="max-w-6xl mx-auto py-16 px-4">
    <h1 class="text-4xl font-black italic mb-12 border-b-8 border-slate-900 pb-4">MA BIBLIOTHÈQUE SCIENTIFIQUE</h1>
    
    <div class="grid md:grid-cols-2 gap-12">
     
      <!-- LIVRE 1 : GESTATION NUMÉRIQUE -->
      <a href="/blog/uterus-productique-tome1" class="group cursor-pointer block">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(37,99,235,1)] group-hover:shadow-none transition-all">
          <div class="text-blue-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">L'Utérus Productique</h2>
            <div class="h-2 w-20 bg-blue-500 mb-4"></div>
            <p class="text-blue-100 text-lg font-bold italic">Tome 1 : Gestation d'une Technologie Éducative Numérique</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Instrumentation & Alchimie Algorithmique</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Comment" : L'algorithme comme milieu nutritif de l'apprentissage.</p>
      </div>

      <!-- LIVRE 2 : GESTATION PRODUCTIVE -->
      <a href="/blog/uterus-productique-tome2" class="group cursor-pointer block">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(234,179,8,1)] group-hover:shadow-none transition-all">
          <div class="text-yellow-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">L'Utérus Productique</h2>
            <div class="h-2 w-20 bg-yellow-500 mb-4"></div>
            <p class="text-yellow-100 text-lg font-bold italic">Tome 2 : Gestation d'une Technologie Éducative Productive</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Impact Social & Économie du Savoir</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Pour quoi" : De la solitude artisanale à la démocratisation du savoir.</p>
      </div>

      <!-- LIVRE 6 : LA FLOTTE DES NAVIGATEURS -->
      <a href="/blog/flotte-navigateurs" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(168,85,247,1)] group-hover:shadow-none transition-all">
          <div class="text-purple-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">La Flotte des Navigateurs</h2>
          <div class="h-2 w-20 bg-purple-500 mb-4"></div>
          <p class="text-purple-100 text-lg font-bold italic">Tome 6 : De l'autonomie individuelle à l'intelligence collective</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Communauté & Transmission</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Pour demain" : L'apprenant solitaire découvre qu'il n'est plus seul.</p>
      </a>
      
      <!-- LIVRE 3 : L'ÉCLOSION DES OBSTACLES -->
      <a href="/blog/eclosion-obstacles" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(249,115,22,1)] group-hover:shadow-none transition-all">
          <div class="text-orange-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">L'Éclosion des Obstacles</h2>
          <div class="h-2 w-20 bg-orange-500 mb-4"></div>
          <p class="text-orange-100 text-lg font-bold italic">Tome 3 : De l'erreur à la métamorphose</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Bachelard & Transformation Cognitive</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Par où" : Comment l'erreur devient le levier du changement d'esprit.</p>
      </a>

      <!-- LIVRE 4 : LE PROTOCOLE BARGE ROUSSE -->
      <a href="/blog/protocole-barge-rousse" class="group cursor-pointer block">
        <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(14,165,233,1)] group-hover:shadow-none transition-all">
          <div class="text-sky-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
            <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">Le Protocole Barge Rousse</h2>
            <div class="h-2 w-20 bg-sky-500 mb-4"></div>
            <p class="text-sky-100 text-lg font-bold italic">L'autonomie comme réflexe magnétique dans le flux d'information.</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Bio-résilience & Auto-régulation</p>
        </div>
        <p class="mt-8 font-bold text-slate-700">Le "Comment survivre" : Transformer l'apprenant en un navigateur capable de traverser 11 000 km de complexité.</p>
      </div>
      <!-- LIVRE 5 : LA MAINTENANCE DU VOYAGEUR -->
      <a href="/blog/maintenance-voyageur" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(34,197,94,1)] group-hover:shadow-none transition-all">
          <div class="text-green-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">La Maintenance du Voyageur</h2>
          <div class="h-2 w-20 bg-green-500 mb-4"></div>
          <p class="text-green-100 text-lg font-bold italic">Tome 5 : L'intervalle de tolérance du vivant</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Usure & Résilience Cognitive</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Comment durer" : Calculer l'usure pour garantir la traversée.</p>
      </div>

      <a href="/blog/protocole-barge-rousse" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(14,165,233,1)] group-hover:shadow-none transition-all">
          <div class="text-sky-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">Le Protocole Barge Rousse</h2>
          <div class="h-2 w-20 bg-sky-500 mb-4"></div>
          <p class="text-sky-100 text-lg font-bold italic">L'autonomie comme réflexe magnétique dans le flux d'information.</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Bio-résilience & Auto-régulation</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Comment survivre" : Transformer l'apprenant en navigateur capable de traverser 11 000 km de complexité.</p>
      </a>

      <a href="/blog/maintenance-voyageur" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(34,197,94,1)] group-hover:shadow-none transition-all">
          <div class="text-green-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">La Maintenance du Voyageur</h2>
          <div class="h-2 w-20 bg-green-500 mb-4"></div>
          <p class="text-green-100 text-lg font-bold italic">Tome 5 : L'intervalle de tolérance du vivant</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Usure & Résilience Cognitive</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Comment durer" : Calculer l'usure pour garantir la traversée.</p>
      </a>
      <!-- FICHE 07 : LE PROTOCOLE MARTINET -->
      <div class="border-4 border-slate-900 p-6 bg-purple-50 shadow-[8px_8px_0px_0px_rgba(168,85,247,1)] my-8">
      <div class="flex justify-between items-start">
          <h3 class="text-xl font-black uppercase">Onde de Choc N°07 : La Résilience Bimodale</h3>
          <span class="bg-purple-600 text-white text-xs px-2 py-1 font-bold">FICHE PÉDAGOGIQUE</span>
      </div>
      <p class="mt-4 text-slate-700 font-medium">
          Inspirée par le Martinet Noir, cette fiche enseigne à l'apprenant comment "s'hydrater en vol" 
          (capter les ressources de son environnement) et gérer son sommeil pour une endurance cognitive durable.
      </p>
      <div class="mt-6 flex gap-4">
          <a href="/docs/fiche-martinet.pdf" class="bg-slate-900 text-white px-4 py-2 font-bold text-sm uppercase hover:translate-y-1 transition-all">📄 Télécharger la Fiche (PDF)</a>
          <a href="/test-bimodal" class="border-2 border-slate-900 px-4 py-2 font-bold text-sm uppercase hover:bg-purple-100 transition-all">🧪 Tester mon mode bimodal</a>
      </div>
      </div>

      <!-- LIVRE 7 : LE PROTOCOLE MARTINET -->
      <a href="/blog/protocole-martinet" class="group cursor-pointer block">
      <div class="aspect-[3/4] bg-slate-900 p-8 flex flex-col justify-between border-4 border-slate-900 shadow-[12px_12px_0px_0px_rgba(168,85,247,1)] group-hover:shadow-none transition-all">
          <div class="text-purple-400 font-black text-xl tracking-tighter italic">KRECOSYS.6</div>
          <div>
          <h2 class="text-white text-3xl font-black leading-tight uppercase mb-4">Le Protocole Martinet</h2>
          <div class="h-2 w-20 bg-purple-500 mb-4"></div>
          <p class="text-purple-100 text-lg font-bold italic">Tome 7 : L'art du sommeil unilatéral</p>
          </div>
          <p class="text-slate-400 text-xs font-mono uppercase">Résilience Bimodale & Vigilance Durable</p>
      </div>
      <p class="mt-8 font-bold text-slate-700">Le "Comment durer sans s'épuiser" : La maintenance prédictive de l'apprenant.</p>
      </a>
      
      <!-- Section Test du Voyageur -->
      <section class="mt-16">
        <VoyageurTest />
      </section>
    </div>
  </section>
</BaseLayout>