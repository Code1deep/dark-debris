---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Projets techniques" description="Dépôts GitHub et documentation technique">
  <section>
    <h1 class="text-3xl font-bold text-center mb-8">Projets et dépôts GitHub</h1>
    
    <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
      
      <!-- Carte 1 : BDI-prototype -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">BDI-prototype</h3>
        <p class="text-slate-600 mb-4">Système de collecte de données et simulation (Python). Architecture découplée pour la recherche doctorale.</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Python</span>
          <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">MQTT</span>
        </div>
        <a href="https://github.com/Code1deep/BDI-prototype" class="font-bold underline hover:text-blue-600" target="_blank">Voir le dépôt GitHub →</a>
      </div>

      <!-- Carte 2 : living-lab-sensors -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">living-lab-sensors</h3>
        <p class="text-slate-600 mb-4">Code embarqué (ESP32/C++) pour le monitoring d'aquaponie. Gestion de la calibration et watchdog matériel.</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-orange-100 text-orange-800 text-xs px-2 py-1 rounded">C++ / Arduino</span>
          <span class="bg-purple-100 text-purple-800 text-xs px-2 py-1 rounded">IoT</span>
        </div>
        <a href="https://github.com/Code1deep/living-lab-sensors" class="font-bold underline hover:text-blue-600" target="_blank">Voir le dépôt GitHub →</a>
      </div>

      <!-- Carte 3 : obstacle-detection -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">obstacle-detection</h3>
        <p class="text-slate-600 mb-4">Algorithmes d'identification des obstacles cognitifs (linéarité, temporalité, proportionnalité).</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">Python</span>
          <span class="bg-yellow-100 text-yellow-800 text-xs px-2 py-1 rounded">IA / Logique</span>
        </div>
        <a href="https://github.com/Code1deep/obstacle-detection" class="font-bold underline hover:text-blue-600" target="_blank">Voir le dépôt GitHub →</a>
      </div>

      <!-- Carte 4 : dashboard -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">dashboard</h3>
        <p class="text-slate-600 mb-4">Configuration Grafana pour la visualisation temps réel de la Base de Données Intelligente.</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-red-100 text-red-800 text-xs px-2 py-1 rounded">Grafana</span>
          <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">InfluxDB</span>
        </div>
        <a href="https://github.com/Code1deep/dashboard" class="font-bold underline hover:text-blue-600" target="_blank">Voir le dépôt GitHub →</a>
      </div>

      <!-- Carte 5 : docs -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">docs</h3>
        <p class="text-slate-600 mb-4">Documentation technique, schémas d'architecture et manuels utilisateur.</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">PDF</span>
          <span class="bg-gray-100 text-gray-800 text-xs px-2 py-1 rounded">Schémas</span>
        </div>
        <a href="https://github.com/Code1deep/docs" class="font-bold underline hover:text-blue-600" target="_blank">Voir le dépôt GitHub →</a>
      </div>

      <!-- Carte 6 : BAC Agro'Lab (Zenodo) -->
      <div class="border-2 border-slate-900 p-6 rounded-xl shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
        <h3 class="text-xl font-bold mb-2">BAC Agro'Lab</h3>
        <p class="text-slate-600 mb-4">Curriculum 4.0 pour l'apprentissage des systèmes complexes. Licence ouverte CC BY-SA.</p>
        <div class="flex gap-2 mb-4">
          <span class="bg-green-100 text-green-800 text-xs px-2 py-1 rounded">CC BY-SA</span>
          <span class="bg-blue-100 text-blue-800 text-xs px-2 py-1 rounded">DOI</span>
        </div>
        <a href="https://zenodo.org" class="font-bold underline hover:text-blue-600" target="_blank">Voir sur Zenodo →</a>
      </div>
    </div>
    
    <div class="text-center mt-8 text-gray-500 text-sm">
      <p>Tous les dépôts sont publics sous licence MIT. Les versions beta sont accessibles.</p>
    </div>
  </section>
</BaseLayout>
